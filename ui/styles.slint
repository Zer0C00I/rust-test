export global Theme {
    // Colors
    out property <color> bg: #1e1e2e;
    out property <color> surface: #313244;
    out property <color> surface-hover: #45475a;
    out property <color> primary: #89b4fa;
    out property <color> primary-hover: #74c7ec;
    out property <color> text: #cdd6f4;
    out property <color> text-dim: #a6adc8;
    out property <color> danger: #f38ba8;
    out property <color> success: #a6e3a1;
    out property <color> warning: #f9e2af;
    out property <color> info: #89b4fa;
    out property <color> sidebar-bg: #181825;
    out property <color> border: #585b70;
    out property <color> input-bg: #45475a;

    // Spacing
    out property <length> pad-sm: 8px;
    out property <length> pad-md: 16px;
    out property <length> pad-lg: 24px;

    // Font sizes
    out property <length> font-sm: 12px;
    out property <length> font-md: 14px;
    out property <length> font-lg: 18px;
    out property <length> font-xl: 24px;
}
